# Obrigatória — chave da Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Opcional — chave da DeepSeek (platform.deepseek.com). Sem ela, o contra-check fica desativado e o resto funciona normalmente.
DEEPSEEK_API_KEY=sk-...

# Opcional — Postgres do Railway (login e casos salvos). No Railway, use a referência: ${{Postgres.DATABASE_URL}}
DATABASE_URL=

# Recomendada se usar contas — segredo fixo das sessões (qualquer frase longa aleatória). Sem ele, todo redeploy desloga os usuários.
JWT_SECRET=

# Opcionais — anti-bot Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
